VITE_API_BASE_URL=http://localhost:3003/api
VITE_SUPABASE_URL=YOUR_URL
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# API origin (no /api suffix). In Vite dev, if set, Socket.IO connects here directly (recommended). If unset, the client uses the Vite origin and proxies /socket.io → localhost:3003.
VITE_SOCKET_URL=http://localhost:3003
