# --- Local dev (copy to frontend/.env) ---
# API: use either name (same value). `api.ts` prefers VITE_API_URL; build accepts both.
VITE_API_BASE_URL=http://localhost:3003/api
# VITE_API_URL=https://your-api.example.com/api
VITE_SUPABASE_URL=YOUR_URL
VITE_SUPABASE_ANON_KEY=YOUR_ANON_KEY
# Optional. In dev, if unset, Socket.IO uses the Vite origin + proxy. In production, if unset, the same host as VITE_API_BASE_URL is used ( /api stripped ).
VITE_SOCKET_URL=http://localhost:3003

# --- Production (Cloudflare Pages, GitHub Actions, etc.) ---
# MUST be present when `vite build` runs — they are compiled into the JS bundle, not read at runtime from the browser.
# Example:
#   VITE_API_BASE_URL=https://teamchat-api.wanpanel.ai/api
#   VITE_SOCKET_URL=https://teamchat-api.wanpanel.ai
#   VITE_SUPABASE_URL=https://xxxx.supabase.co
#   VITE_SUPABASE_ANON_KEY=eyJ...
# Pages: Project → Settings → Environment variables → Production (and Preview if needed) → redeploy.
# Variables are injected into process.env during `vite build`; the build also reads frontend/.env.production if present.
